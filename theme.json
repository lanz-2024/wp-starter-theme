{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "color": {
      "palette": [
        { "slug": "primary",      "color": "#2563eb", "name": "Primary" },
        { "slug": "primary-dark", "color": "#1d4ed8", "name": "Primary Dark" },
        { "slug": "secondary",    "color": "#7c3aed", "name": "Secondary" },
        { "slug": "neutral-900",  "color": "#111827", "name": "Neutral 900" },
        { "slug": "neutral-100",  "color": "#f3f4f6", "name": "Neutral 100" },
        { "slug": "white",        "color": "#ffffff", "name": "White" },
        { "slug": "black",        "color": "#000000", "name": "Black" }
      ],
      "gradients": [
        {
          "slug": "primary-gradient",
          "gradient": "linear-gradient(135deg, #2563eb 0%, #7c3aed 100%)",
          "name": "Primary Gradient"
        }
      ],
      "duotone": []
    },
    "typography": {
      "fluid": true,
      "fontFamilies": [
        {
          "slug": "sans",
          "fontFamily": "Inter, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
          "name": "Sans"
        },
        {
          "slug": "mono",
          "fontFamily": "'JetBrains Mono', Menlo, Monaco, Consolas, 'Courier New', monospace",
          "name": "Mono"
        }
      ],
      "fontSizes": [
        { "slug": "xs",   "size": "clamp(0.75rem, 1vw, 0.875rem)",  "name": "Extra Small" },
        { "slug": "sm",   "size": "clamp(0.875rem, 1.5vw, 1rem)",   "name": "Small" },
        { "slug": "base", "size": "clamp(1rem, 2vw, 1.125rem)",     "name": "Base" },
        { "slug": "lg",   "size": "clamp(1.125rem, 2.5vw, 1.25rem)","name": "Large" },
        { "slug": "xl",   "size": "clamp(1.25rem, 3vw, 1.5rem)",    "name": "XL" },
        { "slug": "2xl",  "size": "clamp(1.5rem, 4vw, 2rem)",       "name": "2XL" },
        { "slug": "3xl",  "size": "clamp(2rem, 5vw, 3rem)",         "name": "3XL" }
      ]
    },
    "spacing": {
      "spacingSizes": [
        { "slug": "xs",  "size": "0.5rem", "name": "XS" },
        { "slug": "sm",  "size": "1rem",   "name": "SM" },
        { "slug": "md",  "size": "1.5rem", "name": "MD" },
        { "slug": "lg",  "size": "2rem",   "name": "LG" },
        { "slug": "xl",  "size": "3rem",   "name": "XL" },
        { "slug": "2xl", "size": "4rem",   "name": "2XL" },
        { "slug": "3xl", "size": "6rem",   "name": "3XL" }
      ],
      "units": [ "%", "px", "em", "rem", "vh", "vw" ]
    },
    "layout": {
      "contentSize": "720px",
      "wideSize": "1200px"
    },
    "blocks": {
      "core/button": {
        "color": {
          "background": true,
          "text": true
        }
      },
      "core/code": {
        "typography": {
          "fontFamily": true
        }
      }
    }
  },
  "styles": {
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--sans)",
      "fontSize": "var(--wp--preset--font-size--base)",
      "lineHeight": "1.6"
    },
    "color": {
      "background": "var(--wp--preset--color--white)",
      "text": "var(--wp--preset--color--neutral-900)"
    },
    "spacing": {
      "blockGap": "var(--wp--preset--spacing--md)"
    },
    "elements": {
      "link": {
        "color": {
          "text": "var(--wp--preset--color--primary)"
        },
        ":hover": {
          "color": {
            "text": "var(--wp--preset--color--primary-dark)"
          }
        }
      },
      "h1": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--3xl)",
          "fontWeight": "700",
          "lineHeight": "1.2"
        }
      },
      "h2": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--2xl)",
          "fontWeight": "700",
          "lineHeight": "1.25"
        }
      },
      "h3": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--xl)",
          "fontWeight": "600",
          "lineHeight": "1.3"
        }
      },
      "h4": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--lg)",
          "fontWeight": "600",
          "lineHeight": "1.4"
        }
      },
      "h5": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--base)",
          "fontWeight": "600"
        }
      },
      "h6": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--sm)",
          "fontWeight": "600"
        }
      },
      "button": {
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "var(--wp--preset--color--white)"
        },
        "typography": {
          "fontWeight": "600"
        },
        ":hover": {
          "color": {
            "background": "var(--wp--preset--color--primary-dark)"
          }
        }
      }
    }
  },
  "customTemplates": [
    { "name": "blank",            "title": "Blank",             "postTypes": ["page"] },
    { "name": "single-portfolio", "title": "Portfolio Single",  "postTypes": ["portfolio"] }
  ],
  "templateParts": [
    { "area": "header",       "name": "header",   "title": "Header" },
    { "area": "footer",       "name": "footer",   "title": "Footer" },
    { "area": "uncategorized","name": "sidebar",  "title": "Sidebar" },
    { "area": "uncategorized","name": "comments", "title": "Comments" }
  ]
}
