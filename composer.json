{
  "name": "lanz2024/wp-starter-theme",
  "description": "Modern WordPress block theme demonstrating theme.json v3, FSE, block patterns, Customizer, and PSR-4 architecture.",
  "type": "wordpress-theme",
  "license": "GPL-2.0-or-later",
  "authors": [
    {
      "name": "Lan",
      "homepage": "https://github.com/lanz-2024"
    }
  ],
  "require": {
    "php": "^8.5"
  },
  "require-dev": {
    "phpunit/phpunit": "^11",
    "wp-coding-standards/wpcs": "^3",
    "phpstan/phpstan": "^2",
    "szepeviktor/phpstan-wordpress": "^2",
    "brain/monkey": "^2",
    "squizlabs/php_codesniffer": "^3"
  },
  "autoload": {
    "psr-4": {
      "WPStarterTheme\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "WPStarterTheme\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "phpcs": "phpcs --standard=WordPress src/",
    "phpcbf": "phpcbf --standard=WordPress src/",
    "phpstan": "phpstan analyse src/ --level=5",
    "test": "phpunit"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
