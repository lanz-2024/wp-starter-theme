{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "title": "Minimal",
  "slug": "minimal",
  "settings": {
    "color": {
      "palette": [
        { "slug": "primary",      "color": "#1a1a1a", "name": "Primary" },
        { "slug": "primary-dark", "color": "#000000", "name": "Primary Dark" },
        { "slug": "secondary",    "color": "#555555", "name": "Secondary" },
        { "slug": "neutral-900",  "color": "#1a1a1a", "name": "Neutral 900" },
        { "slug": "neutral-100",  "color": "#f5f5f5", "name": "Neutral 100" },
        { "slug": "white",        "color": "#ffffff", "name": "White" },
        { "slug": "black",        "color": "#000000", "name": "Black" }
      ]
    },
    "typography": {
      "fontSizes": [
        { "slug": "xs",   "size": "0.75rem",  "name": "Extra Small" },
        { "slug": "sm",   "size": "0.875rem", "name": "Small" },
        { "slug": "base", "size": "1rem",     "name": "Base" },
        { "slug": "lg",   "size": "1.125rem", "name": "Large" },
        { "slug": "xl",   "size": "1.25rem",  "name": "XL" },
        { "slug": "2xl",  "size": "1.5rem",   "name": "2XL" },
        { "slug": "3xl",  "size": "2rem",     "name": "3XL" }
      ]
    },
    "spacing": {
      "spacingSizes": [
        { "slug": "xs",  "size": "0.25rem", "name": "XS" },
        { "slug": "sm",  "size": "0.75rem", "name": "SM" },
        { "slug": "md",  "size": "1.25rem", "name": "MD" },
        { "slug": "lg",  "size": "1.75rem", "name": "LG" },
        { "slug": "xl",  "size": "2.5rem",  "name": "XL" },
        { "slug": "2xl", "size": "3.5rem",  "name": "2XL" },
        { "slug": "3xl", "size": "5rem",    "name": "3XL" }
      ]
    }
  },
  "styles": {
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--sans)",
      "fontSize": "var(--wp--preset--font-size--base)",
      "lineHeight": "1.7",
      "fontWeight": "400"
    },
    "color": {
      "background": "#ffffff",
      "text": "#1a1a1a"
    },
    "elements": {
      "link": {
        "color": {
          "text": "#1a1a1a"
        },
        "typography": {
          "textDecoration": "underline"
        },
        ":hover": {
          "color": {
            "text": "#000000"
          }
        }
      },
      "button": {
        "color": {
          "background": "#1a1a1a",
          "text": "#ffffff"
        },
        "border": {
          "radius": "2px"
        },
        ":hover": {
          "color": {
            "background": "#000000"
          }
        }
      },
      "h1": {
        "typography": {
          "fontWeight": "300",
          "letterSpacing": "-0.02em"
        }
      },
      "h2": {
        "typography": {
          "fontWeight": "300",
          "letterSpacing": "-0.01em"
        }
      },
      "h3": {
        "typography": {
          "fontWeight": "400"
        }
      }
    }
  }
}
